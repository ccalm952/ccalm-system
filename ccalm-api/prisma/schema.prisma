generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  user
  admin
}

enum AttendancePunchType {
  morning_in
  morning_out
  afternoon_in
  afternoon_out
}

enum AttendanceRecordSource {
  normal
  makeup
}

enum AttendanceMakeupRequestStatus {
  pending
  approved
  rejected
}

enum ScheduleShiftType {
  full_rest
  morning_rest
  afternoon_rest
}

enum WarehouseTxnType {
  in
  out
  adjust
}

enum WarehouseTxnBizType {
  purchase
  use
  return_in
  return_out
  adjust_in
  adjust_out
}

model User {
  id           String             @id @default(uuid())
  username     String             @unique
  passwordHash String
  displayName  String
  avatarUrl    String             @default("")
  role         UserRole           @default(user)
  leaveInitialBalance Float         @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  records              AttendanceRecord[]
  makeupRequests       AttendanceMakeupRequest[] @relation("MakeupApplicant")
  reviewedMakeupRequests AttendanceMakeupRequest[] @relation("MakeupReviewer")
  scheduleEntries      ScheduleEntry[]
  warehouseTxnsOperated WarehouseTxn[]          @relation("WarehouseTxnOperator")
}

model GeofenceConfig {
  id        String   @id @default("global")
  enabled   Boolean  @default(false)
  centerLat Float
  centerLng Float
  radiusM   Int
  label     String   @default("")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ShiftConfig {
  id                       String   @id @default("global")
  morningLabel             String   @default("上午")
  morningRangeStart        String   @default("08:30")
  morningRangeEnd          String   @default("12:00")
  afternoonLabel           String   @default("下午")
  afternoonRangeStart      String   @default("14:30")
  afternoonRangeEnd        String   @default("18:00")
  morningInWindowStart     String   @default("08:25")
  morningInWindowEnd       String   @default("09:00")
  morningOutWindowStart    String   @default("11:00")
  morningOutWindowEnd      String   @default("14:20")
  afternoonInWindowStart   String   @default("14:25")
  afternoonInWindowEnd     String   @default("15:00")
  afternoonOutWindowStart  String   @default("17:00")
  afternoonOutWindowEnd    String   @default("20:20")
  overtimeMorningNormalEnd String   @default("12:00")
  overtimeAfternoonNormalEnd String @default("18:00")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
}

model AttendanceRecord {
  id        String                 @id @default(uuid())
  userId    String
  user      User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      AttendancePunchType
  punchTime DateTime               @default(now())
  latitude  Float
  longitude Float
  address   String                 @default("")
  source    AttendanceRecordSource @default(normal)
  createdAt DateTime               @default(now())

  @@index([userId, punchTime])
  @@index([type, punchTime])
}

model AttendanceMakeupRequest {
  id           String                        @id @default(uuid())
  userId       String
  user         User                          @relation("MakeupApplicant", fields: [userId], references: [id], onDelete: Cascade)
  date         String
  type         AttendancePunchType
  punchTime    DateTime
  reason       String
  status       AttendanceMakeupRequestStatus @default(pending)
  reviewedBy   String?
  reviewer     User?                         @relation("MakeupReviewer", fields: [reviewedBy], references: [id], onDelete: SetNull)
  reviewedAt   DateTime?
  rejectReason String                        @default("")
  createdAt    DateTime                      @default(now())
  updatedAt    DateTime                      @updatedAt

  @@index([userId, date])
  @@index([status, createdAt])
}

model ScheduleEntry {
  id        String            @id @default(uuid())
  userId    String
  user      User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String
  shiftType ScheduleShiftType
  isManual  Boolean           @default(false)
  createdAt DateTime          @default(now())
  updatedAt DateTime          @updatedAt

  @@unique([userId, date])
  @@index([date])
}

model ScheduleMonthConfig {
  month          String   @id
  monthAllowance Float    @default(0)
  updatedAt      DateTime @updatedAt
}

model WarehouseItem {
  id                Int            @id @default(autoincrement())
  code              String         @unique
  name              String
  category          String         @default("其他")
  spec              String         @default("")
  unit              String         @default("个")
  brand             String         @default("")
  manufacturer      String         @default("")
  supplierName      String         @default("")
  currentQty        Int            @default(0)
  lastPurchasePrice Float          @default(0)
  enabled           Boolean        @default(true)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt
  txns              WarehouseTxn[]

  @@index([name])
  @@index([category])
}

model WarehouseTxn {
  id             Int                 @id @default(autoincrement())
  itemId         Int
  item           WarehouseItem       @relation(fields: [itemId], references: [id], onDelete: Restrict)
  type           WarehouseTxnType
  bizType        WarehouseTxnBizType
  qty            Int
  unitPrice      Float               @default(0)
  amount         Float               @default(0)
  occurDate      String
  operatorUserId String?
  operatorUser   User?               @relation("WarehouseTxnOperator", fields: [operatorUserId], references: [id], onDelete: SetNull)
  createdAt      DateTime            @default(now())

  @@index([itemId, occurDate])
  @@index([type, occurDate])
}

/// 种植模块：患者（与系统登录 User 无关）
model ImplantPatient {
  id        Int            @id @default(autoincrement())
  name      String
  phone     String
  chartNo   String         @default("")
  gender    String         @default("")
  birthday  String?
  age       Int?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  visits    ImplantVisit[]

  @@index([name])
  @@index([phone])
}

model ImplantVisit {
  id        Int            @id @default(autoincrement())
  patientId Int
  patient   ImplantPatient @relation(fields: [patientId], references: [id], onDelete: Cascade)
  visitDate String
  remark    String?
  staff     String?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  teeth     ImplantTooth[]

  @@index([patientId, visitDate])
}

model ImplantTooth {
  id           Int          @id @default(autoincrement())
  visitId      Int
  visit        ImplantVisit @relation(fields: [visitId], references: [id], onDelete: Cascade)
  toothNo      String?
  implantBrand String?
  implantModel String?
  toothRemark  String?

  @@index([visitId])
}

model ImplantInventory {
  id         Int    @id @default(autoincrement())
  brand      String
  model      String
  supplement Int    @default(0)
  used       Int    @default(0)

  @@unique([brand, model])
}
